---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ArrowLeft, ArrowUpRight, Github, Calendar, Code2, Link, ArrowRight } from 'lucide-react';
import AudioPlayer from '../../components/AudioPlayer';
import { NotebookCard } from '../../components/ui/NotebookCard';
import { Tag } from '../../components/ui/Tag';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<Layout title={project.data.title}>
  <section class="pt-28 pb-24 px-6 min-h-screen">
    <div class="max-w-4xl mx-auto">
      <a
        href="/projects"
        class="group flex items-center gap-2 text-muted hover:text-text transition-colors mb-10"
      >
        <ArrowLeft className="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
        Back to Projects
      </a>

      {/* Header */}
      <div class="mb-12 border-b border-border/50 pb-8">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <div class="flex items-center gap-2 text-muted font-medium bg-surface border border-border/40 px-3 py-1 rounded-full text-xs font-mono">
            <Calendar className="w-3.5 h-3.5" />
            <span>{project.data.date}</span>
          </div>
        </div>

        <h1 class="display-serif text-3xl md:text-5xl lg:text-6xl text-text mb-6 leading-[1.1]">
          {project.data.title}
        </h1>

        <p class="text-xl md:text-2xl text-muted leading-relaxed font-light max-w-3xl">
          {project.data.description}
        </p>
      </div>

      <div class="grid lg:grid-cols-[1fr_300px] gap-12 items-start">
        {/* Mobile Sidebar */}
        <div class="lg:hidden mb-8 space-y-6">
          {project.data.audioUrl && (
            <AudioPlayer src={project.data.audioUrl} title="Listen to Overview" client:load />
          )}

          <NotebookCard>
            <div class="flex items-center gap-2 text-text font-bold mb-4 font-mono text-sm">
              <Link className="w-4 h-4 text-note" />
              <h3>Project Links</h3>
            </div>
            <div class="flex flex-col gap-3">
              {project.data.demoUrl && (
                <a href={project.data.demoUrl} target="_blank" rel="noreferrer"
                   class="flex items-center justify-center gap-2 px-4 py-2 bg-text hover:bg-muted text-bg font-semibold rounded-lg transition-colors text-sm">
                  <span>View Live Demo</span>
                  <ArrowUpRight className="w-4 h-4" />
                </a>
              )}
              {project.data.repoUrl && (
                <a href={project.data.repoUrl} target="_blank" rel="noreferrer"
                   class="flex items-center justify-center gap-2 px-4 py-2 bg-surface hover:bg-surface2 text-text font-semibold rounded-lg transition-colors border border-border/60 text-sm">
                  <Github className="w-4 h-4" />
                  <span>Source Code</span>
                </a>
              )}
            </div>
          </NotebookCard>

          <NotebookCard>
            <div class="flex items-center gap-2 text-text font-bold mb-4 font-mono text-sm">
              <Code2 className="w-4 h-4 text-note" />
              <h3>Tech Stack</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {project.data.techStack.map((tech: string) => (
                <Tag key={tech}>{tech}</Tag>
              ))}
            </div>
          </NotebookCard>
        </div>

        {/* Main Content */}
        <article class="min-w-0 prose prose-lg max-w-none
            prose-headings:font-serif prose-headings:font-bold prose-headings:text-text
            prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-8 prose-h2:pb-4 prose-h2:border-b prose-h2:border-border/50
            prose-h3:text-2xl prose-h3:text-text prose-h3:mt-12 prose-h3:mb-6
            prose-p:text-muted prose-p:leading-8 prose-p:mb-8
            prose-a:text-note prose-a:no-underline hover:prose-a:underline
            prose-strong:text-text prose-strong:font-semibold
            prose-li:text-muted prose-li:marker:text-green prose-li:mb-4
            prose-blockquote:border-l-green prose-blockquote:bg-surface/50 prose-blockquote:py-6 prose-blockquote:px-8 prose-blockquote:rounded-r-lg prose-blockquote:not-italic prose-blockquote:text-muted prose-blockquote:mb-8
            prose-pre:bg-surface prose-pre:border prose-pre:border-border/60
            [&>h2:first-child]:!mt-0 [&>*:first-child]:!mt-0
          ">
          <Content />
        </article>

        {/* Desktop Sidebar */}
        <aside class="hidden lg:block sticky top-32 space-y-6">
          {project.data.audioUrl && (
            <AudioPlayer src={project.data.audioUrl} title="Listen to Overview" client:load />
          )}

          <NotebookCard>
            <div class="flex items-center gap-2 text-text font-bold mb-4 font-mono text-sm">
              <Link className="w-4 h-4 text-note" />
              <h3>Project Links</h3>
            </div>
            <div class="flex flex-col gap-3">
              {project.data.demoUrl && (
                <a href={project.data.demoUrl} target="_blank" rel="noreferrer"
                   class="flex items-center justify-center gap-2 px-4 py-2.5 bg-text hover:bg-muted text-bg font-semibold rounded-lg transition-colors text-sm">
                  <span>View Live Demo</span>
                  <ArrowUpRight className="w-4 h-4" />
                </a>
              )}
              {project.data.repoUrl && (
                <a href={project.data.repoUrl} target="_blank" rel="noreferrer"
                   class="flex items-center justify-center gap-2 px-4 py-2.5 bg-surface hover:bg-surface2 text-text font-semibold rounded-lg transition-colors border border-border/60 text-sm">
                  <Github className="w-4 h-4" />
                  <span>Source Code</span>
                </a>
              )}
            </div>
          </NotebookCard>

          <NotebookCard>
            <div class="flex items-center gap-2 text-text font-bold mb-4 font-mono text-sm">
              <Code2 className="w-4 h-4 text-note" />
              <h3>Tech Stack</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {project.data.techStack.map((tech: string) => (
                <Tag key={tech}>{tech}</Tag>
              ))}
            </div>
          </NotebookCard>

          <NotebookCard>
            <h4 class="text-text font-bold text-sm mb-2 font-mono">Join the discussion</h4>
            <p class="text-xs text-muted mb-4">
              Feedback on this architecture? Reply via email or Threads.
            </p>
            <a href="https://www.threads.com/@relearn.ing" target="_blank" rel="noreferrer" class="text-xs font-bold text-note hover:text-text flex items-center gap-1">
              Discuss on Threads <ArrowRight className="w-3 h-3" />
            </a>
          </NotebookCard>
        </aside>
      </div>
    </div>
  </section>
</Layout>
