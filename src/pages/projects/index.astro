---
import Layout from '../../layouts/Layout.astro';
import { ProjectList } from '../../components/ProjectList';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const projectsWithContent = sortedProjects.map(project => ({
  slug: project.slug,
  data: project.data,
  body: project.body,
}));
---

<Layout title="Projects">
  <section class="pt-28 pb-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <div class="flex items-start gap-4 mb-4">
          <div>
            <span class="label-mono block mb-2">Portfolio</span>
            <h1 class="display-serif text-4xl md:text-5xl text-text">Engineering Artifacts</h1>
          </div>
        </div>
        <p class="text-muted max-w-xl">
          Tangible proof of concept. These are not just codebases; they are attempts to instantiate specific cognitive models into software.
        </p>
      </div>

      <ProjectList client:load projects={projectsWithContent} />
    </div>
  </section>
</Layout>
