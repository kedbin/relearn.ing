---
import Layout from '../../layouts/Layout.astro';
import { ProjectList } from '../../components/ProjectList';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const projectsWithContent = sortedProjects.map(project => ({
  id: project.id,
  data: project.data,
  body: project.body,
}));
---

<Layout title="Projects">
  <section class="pt-28 pb-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16">
        <h1 class="display-serif text-4xl md:text-5xl text-text mb-4">
          Things I build to learn,<br />solve, and leverage.
        </h1>
        <p class="text-muted max-w-xl mt-4">
          A collection of systems, products, and experiments that explore ideas at the intersection of AI, automation, and digital infrastructure.
        </p>
      </div>

      <ProjectList client:load projects={projectsWithContent} />
    </div>
  </section>
</Layout>
