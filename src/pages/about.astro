---
import Layout from '../layouts/Layout.astro';
import { NotebookCard } from '../components/ui/NotebookCard';
import { HandwrittenNote } from '../components/ui/HandwrittenNote';
import { MetricRow } from '../components/ui/MetricRow';
import { Newsletter } from '../components/home/Newsletter';
---

<Layout title="About">
  <section class="pt-28 pb-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-[1fr_360px] gap-12 items-start">
        {/* Main Content */}
        <div>
          <div class="mb-12">
            <span class="label-mono block mb-3">About</span>
            <h1 class="display-serif text-4xl md:text-5xl text-text mb-4">
              Kim Edrian Binasoy
            </h1>
            <p class="text-xl text-muted mb-8">
              Engineer by training. Builder by obsession.
            </p>

            <div class="prose max-w-none
              prose-p:text-muted prose-p:leading-8 prose-p:mb-6
              prose-a:text-note prose-a:no-underline hover:prose-a:underline
              prose-strong:text-text
            ">
              <p>
                I'm a cloud engineer with 4 years of experience building automation systems for financial services and transportation. My work focuses on infrastructure, AI integration, and workflow optimization.
              </p>
              <p>
                <strong>Relearn.ing</strong> is where I document my experiments in cognitive engineering—applying systematic approaches to learning, productivity, and personal development. It's part lab notebook, part reference, and fully open source.
              </p>
              <p>
                For my professional work and portfolio, visit <a href="https://binasoy.kim" target="_blank" rel="noopener noreferrer">binasoy.kim</a>.
              </p>
            </div>
          </div>

          {/* Principles */}
          <div class="mb-12">
            <h2 class="display-serif text-2xl text-text mb-6">Principles</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {[
                'Based in Earth',
                'Building in public',
                'Shipping tiny things',
                'Learning every day',
              ].map((principle) => (
                <div class="flex items-center gap-3 text-muted">
                  <span class="w-1.5 h-1.5 rounded-full bg-green" />
                  <span>{principle}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Tech Stack */}
          <div class="mb-16">
            <h2 class="display-serif text-2xl text-text mb-6">Technical Stack</h2>
            <div class="flex flex-wrap gap-2">
              {['Azure', 'AWS', 'Python', 'TypeScript', 'Power Platform', 'React', 'Docker', 'Terraform'].map((tech) => (
                <span class="px-3 py-1 bg-surface border border-border/40 rounded-lg text-sm text-muted">
                  {tech}
                </span>
              ))}
            </div>
          </div>

          {/* Newsletter — moved from homepage */}
          <Newsletter client:visible />
        </div>

        {/* Sidebar */}
        <aside class="space-y-6">
          {/* Profile Card */}
          <NotebookCard className="!p-4">
            <div class="relative mb-4">
              {/* Tape */}
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-20 h-6 bg-text/[0.07] rounded-sm z-10 rotate-1 backdrop-blur-sm border border-text/[0.05]" />

              {/* Photo frame with vignette overlay for dark mode */}
              <div class="rounded-xl border border-border/40 overflow-hidden bg-surface2 relative">
                <img
                  src="/profile.jpg"
                  alt="Kim Edrian Binasoy"
                  class="w-full h-72 object-cover object-[center_20%] dark:brightness-[0.82] transition-all"
                />
                {/* Vignette overlay — darkens edges so white bg doesn't glare */}
                <div class="absolute inset-0 pointer-events-none hidden dark:block"
                  style="background: radial-gradient(ellipse at center, transparent 40%, rgb(16 18 24 / 0.65) 100%);"
                />
              </div>
            </div>
            <HandwrittenNote rotation={-1} className="text-center text-sm">
              Work in progress.<br />Always will be.
            </HandwrittenNote>
          </NotebookCard>

          {/* System Status */}
          <NotebookCard>
            <span class="label-mono block mb-4">System Status</span>
            <div class="space-y-1 divide-y divide-border/30">
              <MetricRow label="Sleep" value="7.1h avg" status="degraded" />
              <MetricRow label="Focus" value="12.4h deep work" status="healthy" />
              <MetricRow label="Output" value="8,241 words" status="healthy" />
              <MetricRow label="Wellbeing" value="6.7/10 mood" status="degraded" />
            </div>
          </NotebookCard>
        </aside>
      </div>
    </div>
  </section>
</Layout>
