---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { JournalList } from '../../components/JournalList';

const entries = await getCollection('journal');
const sortedEntries = entries.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const entriesWithContent = sortedEntries.map(entry => ({
  id: entry.id,
  data: entry.data,
  body: entry.body,
}));
---

<Layout title="Journal">
  <section class="pt-28 pb-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16">
        <h1 class="display-serif text-4xl md:text-5xl text-text mb-4">Journal</h1>
        <p class="text-muted max-w-xl">
          A log of real-world and thought experiments. Documenting the engineering of professional and personal protocols.
        </p>
      </div>

      <JournalList client:visible entries={entriesWithContent} />
    </div>
  </section>
</Layout>
